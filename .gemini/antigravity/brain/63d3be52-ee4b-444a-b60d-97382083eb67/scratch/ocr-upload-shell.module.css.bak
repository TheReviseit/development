/* Backup of ocr-upload-shell.module.css before redesign */
.surface {
  min-height: 100vh;
  max-width: 100%;
  overflow-x: clip;
  background: rgb(245, 245, 250);
  color: #111827;
}

.shell {
  width: min(1380px, 100%);
  margin: 0 auto;
  padding: 24px 24px 56px;
}

.header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(280px, 640px) minmax(0, 1fr);
  align-items: center;
  gap: 16px;
  margin-bottom: 22px;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 7px;
  min-width: 0;
  color: #64748b;
  font-size: 13px;
  font-weight: 750;
  line-height: 1.3;
  white-space: nowrap;
}

.breadcrumbLink {
  color: inherit;
  text-decoration: none;
  transition: color 140ms ease;
}

.breadcrumbLink:hover {
  color: rgb(240, 49, 46);
}

.breadcrumbSeparator {
  color: #a2adbd;
  font-weight: 800;
}

.breadcrumbCurrent {
  min-width: 0;
  overflow: hidden;
  color: rgb(240, 49, 46);
  text-overflow: ellipsis;
}

.brandBlock {
  display: grid;
  justify-items: center;
  gap: 6px;
  min-width: 0;
  text-align: center;
}

.title {
  margin: 0;
  color: #111827;
  font-size: 30px;
  line-height: 1.2;
  font-weight: 850;
  letter-spacing: 0;
}

.meta {
  margin: 0;
  max-width: 620px;
  color: #64748b;
  font-size: 14px;
  line-height: 1.45;
}

.headerAside {
  display: flex;
  justify-content: flex-end;
  min-width: 0;
}

.confidenceBadge,
.statusBadge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  max-width: 100%;
  padding: 0 12px;
  overflow: hidden;
  border: 1px solid #dbe3ef;
  border-radius: 999px;
  background: #ffffff;
  color: #334155;
  font-size: 13px;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.confidenceBadge {
  border-color: #bbf7d0;
  background: #f0fdf4;
  color: #047857;
}

.initialHero {
  display: grid;
  gap: 14px;
  width: min(1120px, 100%);
  margin: 30px auto 0;
}

.fileInput {
  display: none;
}

.dropzone {
  border: 2px dotted #cbd5e1;
  background: #ffffff;
  color: #111827;
  cursor: pointer;
  font: inherit;
  text-align: center;
  transition:
    background 160ms ease,
    border-color 160ms ease,
    box-shadow 160ms ease,
    transform 160ms ease;
}

.dropzone:hover,
.dropzoneActive {
  border-color: rgb(240, 49, 46);
  background: #fffafa;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.1);
}

.dropzone:focus-visible,
.secondaryButton:focus-visible,
.iconButton:focus-visible,
.segment:focus-visible,
.segmentActive:focus-visible {
  outline: 3px solid rgba(100, 116, 139, 0.24);
  outline-offset: 2px;
}

.dropzoneLarge {
  position: relative;
  display: grid;
  align-content: center;
  justify-items: center;
  gap: 18px;
  width: 100%;
  min-height: clamp(430px, 58vh, 620px);
  padding: 44px 28px;
  overflow: hidden;
  border-radius: 18px;
  box-shadow: 0 22px 58px rgba(15, 23, 42, 0.08);
}

.dropzoneLarge::before {
  content: "";
  position: absolute;
  inset: 18px;
  border: 1.5px dotted #dbe3ef;
  border-radius: 14px;
  pointer-events: none;
}

.uploadIcon,
.compactIcon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #111827;
  color: #ffffff;
}

.uploadIcon {
  width: 74px;
  height: 74px;
  border-radius: 18px;
  box-shadow: 0 18px 34px rgba(15, 23, 42, 0.18);
}

.uploadText {
  display: grid;
  justify-items: center;
  gap: 8px;
  min-width: 0;
  max-width: 620px;
}

.dropTitle {
  max-width: 100%;
  overflow-wrap: anywhere;
  color: #111827;
  font-size: 20px;
  font-weight: 850;
  line-height: 1.2;
}

.dropCopy {
  max-width: min(600px, 100%);
  color: #64748b;
  font-size: 14px;
  line-height: 1.45;
}

.uploadAction {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 18px;
  border-radius: 12px;
  background: #111827;
  color: #ffffff;
  font-size: 14px;
  font-weight: 850;
}

.workspace {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
  gap: 16px;
  align-items: start;
}

.previewPanel,
.statusPanel,
.uploadDock {
  min-width: 0;
  border: 1px solid #e0e7f0;
  border-radius: 14px;
  background: #ffffff;
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.06);
}

.previewPanel {
  display: grid;
  gap: 12px;
  padding-bottom: 14px;
}

.previewToolbar,
.panelHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
  padding: 16px 16px 0;
}

.panelTitle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  margin: 0;
  color: #111827;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: 0;
}

.segmented,
.previewActions,
.actionRow {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.segmented {
  padding: 4px;
  border: 1px solid #d7dee8;
  border-radius: 12px;
  background: #f8fafc;
}

.segment,
.segmentActive,
.secondaryButton,
.iconButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-width: 0;
  min-height: 40px;
  border: 1px solid #d7dee8;
  border-radius: 12px;
  background: #ffffff;
  color: #111827;
  font: inherit;
  font-weight: 800;
  cursor: pointer;
  transition:
    background 160ms ease,
    border-color 160ms ease,
    color 160ms ease;
}

.segment,
.segmentActive {
  min-height: 32px;
  padding: 0 10px;
  border-radius: 9px;
  text-transform: capitalize;
}

.segmentActive {
  border-color: #111827;
  background: #111827;
  color: #ffffff;
}

.secondaryButton {
  padding: 0 12px;
  white-space: nowrap;
}

.secondaryButton:disabled,
.iconButton:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.secondaryButton:hover:not(:disabled),
.iconButton:hover:not(:disabled),
.segment:hover {
  border-color: #aab6c8;
  background: #f8fafc;
}

.previewActions {
  justify-content: flex-end;
  padding: 0 16px;
}

.reader {
  min-height: clamp(420px, 58vh, 690px);
  max-height: calc(100vh - 236px);
  margin: 0 16px;
  overflow: auto;
  border: 1px solid #e2e8f0;
  border-radius: 14px;
  background: #fbfcfd;
  overscroll-behavior: contain;
}

.layoutPreview {
  display: grid;
  align-content: start;
  gap: 0;
  min-height: 100%;
  padding: 24px;
}

.layoutBlock {
  max-width: 880px;
  margin-top: 0;
  margin-bottom: 12px;
  color: #111827;
  font-size: 15px;
  line-height: 1.65;
  overflow-wrap: anywhere;
  white-space: pre-wrap;
}

.plainPreview {
  min-height: 100%;
  margin: 0;
  padding: 18px;
  color: #111827;
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
  font-size: 14px;
  line-height: 1.65;
  overflow-wrap: anywhere;
  white-space: pre-wrap;
}

.previewFooter {
  display: grid;
  gap: 8px;
  min-height: 20px;
  padding: 0 16px;
}

.statusColumn {
  position: sticky;
  top: 84px;
  display: grid;
  gap: 16px;
  min-width: 0;
}

.panelBody {
  display: grid;
  gap: 12px;
  min-width: 0;
  padding: 0 16px 16px;
}

.progressTrack {
  height: 9px;
  overflow: hidden;
  border-radius: 999px;
  background: #e8eef5;
}

.progressTrack span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: rgb(240, 49, 46);
  transition: width 180ms ease;
}

.jobMeta {
  display: grid;
  gap: 10px;
  min-width: 0;
  margin: 0;
}

.jobMeta div {
  min-width: 0;
}

.jobMeta dt {
  color: #64748b;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
}

.jobMeta dd {
  margin: 0;
  overflow-wrap: anywhere;
  color: #111827;
  font-size: 14px;
}

.iconButton {
  width: 40px;
  padding: 0;
}

.readyIcon {
  color: #047857;
}

.bottomUpload {
  position: sticky;
  bottom: 16px;
  z-index: 4;
  margin-top: 16px;
}

.uploadDock {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 12px;
  padding: 10px;
}

.dropzoneCompact {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12px;
  min-width: 0;
  min-height: 70px;
  padding: 12px;
  border-radius: 12px;
  text-align: left;
}

.compactIcon {
  flex: 0 0 44px;
  width: 44px;
  height: 44px;
  border-radius: 12px;
}

.compactText {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.dropzoneCompact .dropTitle {
  display: block;
  overflow: hidden;
  font-size: 15px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dropzoneCompact .dropCopy {
  display: block;
  overflow: hidden;
  font-size: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dockStatus {
  max-width: 280px;
  color: #64748b;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.35;
}

.statusLine {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  color: #475569;
  font-size: 13px;
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.successText {
  color: #047857;
}

.errorText {
  color: #b91c1c;
}

.spin {
  animation: spin 1s linear infinite;
  color: currentColor;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@media (max-width: 980px) {
  .shell {
    padding: 18px 16px 44px;
  }

  .header {
    grid-template-columns: 1fr;
    justify-items: start;
  }

  .brandBlock {
    justify-items: start;
    text-align: left;
  }

  .headerAside {
    justify-content: flex-start;
    width: 100%;
  }

  .workspace {
    grid-template-columns: 1fr;
  }

  .statusColumn {
    position: static;
  }

  .reader {
    max-height: 62vh;
  }
}

@media (max-width: 640px) {
  .title {
    font-size: 28px;
  }

  .dropzoneLarge {
    min-height: min(520px, calc(100vh - 210px));
    padding: 34px 18px;
  }

  .dropzoneLarge::before {
    inset: 12px;
  }

  .uploadIcon {
    width: 64px;
    height: 64px;
  }

  .dropTitle {
    font-size: 18px;
  }

  .previewToolbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .segmented,
  .previewActions {
    width: calc(100% - 32px);
    margin: 0 16px;
  }

  .segmented {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .previewActions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 0;
  }

  .secondaryButton {
    width: 100%;
  }

  .reader {
    min-height: 190px;
    max-height: min(320px, 25vh);
    margin-inline: 12px;
  }

  .previewFooter {
    padding-inline: 12px;
  }

  .uploadDock {
    grid-template-columns: 1fr;
  }

  .dockStatus {
    max-width: none;
    padding: 0 4px 2px;
  }
}

@media (max-width: 420px) {
  .shell {
    padding-inline: 12px;
  }

  .dropzoneCompact {
    min-height: 66px;
    padding: 10px;
  }

  .compactIcon {
    flex-basis: 40px;
    width: 40px;
    height: 40px;
  }

  .dropzoneCompact .dropTitle {
    font-size: 14px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .dropzone,
  .segment,
  .segmentActive,
  .secondaryButton,
  .iconButton,
  .progressTrack span,
  .spin {
    animation: none;
    transition: none;
  }
}

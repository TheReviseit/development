{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/keep-warm",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reconcile-billing",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/expire-bookings",
      "schedule": "0 3 * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
